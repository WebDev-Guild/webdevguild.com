<div class="max-w-min mx-auto  mt-16 bg-black/10 shadow-lg rounded-xl p-12">
  <h2 class="font-display font-bold text-3xl text-center">Join the Newsletter</h2>
  <p class="mt-4 mb-8 text-center">Sign up to get regular updates, sneak peeks, and other goodies.</p>
  <form action="https://app.convertkit.com/forms/3333982/subscriptions" method="post"
    class="newsletter flex items-end gap-4" target="_blank">

    <label>First Name
      <input aria-label="First Name" name="fields[first_name]" placeholder="First Name" type="text"
        class="form-input rounded-lg text-gray-900">
    </label>
    <label>Email Address
      <input name="email_address" aria-label="Email Address" placeholder="Email Address" required type="email"
        class="form-input rounded-lg text-gray-900">
    </label>

    <button type="submit" tabindex={0}
      class="px-4 py-2 bg-gradient-to-br from-indigo-600 to-indigo-900 hover:from-indigo-500 hover:to-indigo-700 active:from-indigo-800 active:to-indigo-900 text-white font-bold rounded-lg focus:ring-2 focus:ring-blue-500 ring ring-transparent ring-offset-1 ring-offset-transparent select-none">
      Subscribe</button>
  </form>
</div>

<script>
  async function submitNewsletter(event) {
    event.preventDefault();
    const button = event.target.querySelector('button')
    button.innerText = "Loading..."
    button.disabled = true;

    const formData = new FormData(event.target);
    const response = await fetch('https://app.convertkit.com/forms/3333982/subscriptions', {
      method: 'POST',
      body: formData
    });

    event.target.parentElement.innerHTML = '<p class="text-center" style="width:26ch;">Thank you for subscribing!</p>';
  }

  document.querySelectorAll("form.newsletter").forEach(form => {
    form.addEventListener("submit", submitNewsletter)
  })
</script>