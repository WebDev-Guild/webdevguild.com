---
// Component Imports
import BaseHead from '../components/BaseHead.astro';
import Logo from '../components/Logo.astro';

// Component Script:
// You can write any JavaScript/TypeScript that you'd like here.
// It will run during the build, but never in the browser.
// All variables are available to use in the HTML template below.
const { title = 'WebDev Guild', description = 'Helping you find success in web development.', permalink = 'https://webdevguild.com/', heroImage } = Astro.props;

// Full Astro Component Syntax:
// https://docs.astro.build/core-concepts/astro-components/
---

<html lang="en" class="bg-gray-100 dark:bg-gray-900">

<head>
  <BaseHead title={title} description={description} permalink={permalink} {heroImage} />

</head>

<body class="text-gray-800 dark:text-gray-100">
  <div
    class="fixed z-0 inset-0 pointer-events-none from-gray-100 to-indigo-100 dark:from-gray-900 dark:to-indigo-900 bg-gradient-to-br" />
  <div class="min-h-screen flex flex-col z-10 relative">
    <main class="flex-grow flex flex-col">
      <slot />
    </main>
    <footer class="w-full mt-32 py-16 bg-indigo-200 dark:bg-gray-900">
      <div class="xl:text-xl max-w-prose w-full mx-auto flex items-center gap-2 px-4">
        <Logo class="h-8 text-gray-800 dark:text-gray-50" />
        WebDev Guild
      </div>
    </footer>
  </div>
</body>

</html>